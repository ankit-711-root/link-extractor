{
  "manifest_version": 3,
  "name": "Link Extractor",
  "description": "Extract and display all links from any webpage — by Ripper",
  "version": "1.0.0",
  "author": "Ripper",
  "homepage_url": "https://github.com/ripper/link-extractor",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}